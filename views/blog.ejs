<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>Blog</title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <div class="container mt-4">
      <h1><%= blog.title %></h1>
      <img src="<%= blog.coverImageURL %>" width="700px" />
      
      <% if (locals.user && blog.createdBy._id.toString() === user._id.toString()) { %>
        <div class="mt-3">
          <a href="/blog/delete/<%= blog._id %>" 
             class="btn btn-danger" 
             onclick="return confirm('Kya aap sach mein ye blog delete karna chahte hain?')">
             Delete Blog
          </a>
        </div>
      <% } %>

      <pre class="mt-3"><%= blog.body %></pre>
    </div>

    <div class="container mt-4">
      <% if (blog.createdBy) { %>
        <img src="<%= blog.createdBy.profileImageURL %>" width="50px" />
        <%= blog.createdBy.fullName %>
      <% } else { %>
        <img src="/images/default.png" width="50px" />
        Unknown User
      <% } %>
    </div>

    <div class="container mt-3">
      <h1>Comments (<%= comments.length %>)</h1>
      </div>

    <%- include('./partials/scripts') %>
  </body>
</html>